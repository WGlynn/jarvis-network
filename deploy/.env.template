# JARVIS Network — Environment Template
# Copy to .env and fill in values. Never commit .env.

# ==================
# Telegram bot setup
# ==================
TELEGRAM_BOT_TOKEN=                # BotFather token (required)
TELEGRAM_OWNER_ID=                 # numeric Telegram user ID of admin (enables /admin_* commands)
BOT_USERNAME=                      # bot's @handle (for mention detection)
WEBHOOK_DOMAIN=                    # public https URL (empty = polling mode)
PORT=8080

# ==================
# LLM provider routing (v0.7 — multi-provider)
# ==================
# Primary provider selector. Choose the cheapest adequate for your use case.
LLM_PROVIDER=anthropic             # anthropic | openrouter | ollama

# Anthropic (Claude) — default path
ANTHROPIC_API_KEY=                 # required when LLM_PROVIDER=anthropic
CLAUDE_MODEL=claude-haiku-4-5-20251001   # triage + default

# OpenRouter (free-tier + open-weights models, OpenAI-compatible API)
OPENROUTER_API_KEY=                # required when LLM_PROVIDER=openrouter
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_BASE=https://openrouter.ai/api/v1

# Ollama (self-hosted local models, OpenAI-compatible)
OLLAMA_BASE=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=ollama              # ollama doesn't check; any string works

# ==================
# Persona
# ==================
# standard | degen | analyst | sensei
JARVIS_PERSONA=standard

# ==================
# Storage
# ==================
DATA_DIR=./data                    # where archive, customers, claimed-txs, logs persist

# ==================
# Archive mirror (optional, opt-in)
# ==================
# If enabled, commits archive dir to a remote git repo every 15min.
# Required for community-auditable ground-truth + future federation.
ARCHIVE_MIRROR_ENABLED=false
ARCHIVE_MIRROR_INTERVAL_MS=900000  # 15 min

# ==================
# Payment gate (v0.1)
# ==================
PAYMENT_USDC_ADDRESS=              # Base-chain USDC address customers pay to
PRICE_USDC_PER_MONTH=29            # subscription price
GRANDFATHERED_CHAT_IDS=            # comma-separated chat IDs that never need subscription

# ==================
# Payment listener (v0.2 — on-chain verification)
# ==================
BASE_RPC_URL=https://mainnet.base.org   # public RPC; override with Alchemy/Infura for throughput
USDC_CONTRACT_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# v0.3 multi-chain — populate when activating:
USDC_CONTRACT_ETHEREUM=0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48
USDC_CONTRACT_ARBITRUM=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# ==================
# Database (for metering + credits ledger, v1+)
# ==================
DATABASE_URL=                      # postgres://user:pass@host/db

# ==================
# TEE attestation (v3 federation)
# ==================
TEE_PROVIDER=                      # sgx | sev-snp | nitro
TEE_ATTESTATION_ENDPOINT=
