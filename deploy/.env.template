# JARVIS Network — Environment Template
# Copy to .env and fill in values. Never commit .env.

# ==================
# Telegram bot setup
# ==================
TELEGRAM_BOT_TOKEN=                # BotFather token (required)
WEBHOOK_DOMAIN=                    # public https URL (empty = polling mode)
PORT=8080

# ==================
# LLM provider routing
# ==================
# Primary provider. JARVIS routes intelligently across these when multiple are set.
ANTHROPIC_API_KEY=                 # required for default triage
OPENAI_API_KEY=                    # optional fallback
LLM_PROVIDER=anthropic             # anthropic | openai | self-hosted
CLAUDE_MODEL=claude-haiku-4-5-20251001   # triage + default

# ==================
# Persona
# ==================
# standard | degen | analyst | sensei
JARVIS_PERSONA=standard

# ==================
# Storage
# ==================
DATA_DIR=./data                    # where archive, user memory, logs persist

# ==================
# Archive mirror (optional, opt-in)
# ==================
# If enabled, commits archive dir to a remote git repo every 15min.
# Required for community-auditable ground-truth + future federation.
ARCHIVE_MIRROR_ENABLED=false
ARCHIVE_MIRROR_INTERVAL_MS=900000  # 15 min

# ==================
# Database (for metering + credits, v1+)
# ==================
DATABASE_URL=                      # postgres://user:pass@host/db

# ==================
# Crypto payment (v2+)
# ==================
# Wallet listener for USDC top-ups. Populated when v2 ships.
PAYMENT_WALLET_ADDRESS=
USDC_CONTRACT_ETHEREUM=0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48
USDC_CONTRACT_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_CONTRACT_ARBITRUM=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# ==================
# TEE attestation (v3+)
# ==================
# Federated shard attestation config. Populated when federation ships.
TEE_PROVIDER=                      # sgx | sev-snp | nitro
TEE_ATTESTATION_ENDPOINT=
